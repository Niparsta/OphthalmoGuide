# =====================================================================
# Шаблон переменных окружения для OphthalmoGuide.
# Скопируйте этот файл в .env и подставьте реальные значения:
#     cp .env.example .env
# Файл .env НЕ коммитится в git (см. .gitignore).
# Значения отсюда автоматически подставляются в docker-compose.yml.
# =====================================================================

# ----- Публичный хост (единая точка для всех localhost) --------------
# Меняется на доменное имя в продакшене, напр. ophthalmoguide.example.com
# Для локальной разработки (по умолчанию):
PUBLIC_HOST=localhost
# Для доступа через VPN (NetBird / WireGuard) - раскомментируйте и укажите ваш IP:
# PUBLIC_HOST=100.85.12.34
# TLS: internal — самоподписанный сертификат (localhost); acme — Let's Encrypt (нужен реальный домен и открытый :80)
TLS_MODE=internal
# E-mail для ACME (при TLS_MODE=acme)
ACME_EMAIL=admin@example.com

# Angie rate limit (опционально, зашито в angie.conf.template):
#   /api, /api/  — 30 запросов/мин на IP
#   /api/*       — 20 запросов/с на IP, burst 40

# ----- PostgreSQL ----------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=postgres
# Имя БД приложения (backend)
APP_DB_NAME=ophthalmoguide
# Имя БД для Authentik
AUTHENTIK_DB_NAME=authentik

# ----- Authentik (OIDC) ----------------------------------------------
# Включение OIDC авторизации (true/false)
AUTHENTIK_ENABLED=true
# Длинный случайный ключ, напр.: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=change_me_long_random_secret_key
AUTHENTIK_CLIENT_ID=change_me_client_id
AUTHENTIK_CLIENT_SECRET=change_me_client_secret

# ----- Grafana (OIDC) ------------------------------------------------
# Создайте OAuth2/OpenID Provider для Grafana в Authentik и вставьте:
GRAFANA_CLIENT_ID=change_me_grafana_client_id
GRAFANA_CLIENT_SECRET=change_me_grafana_client_secret

# ----- SaluteSpeech (Sber) -------------------------------------------
# Authorization key из личного кабинета SberDevices (base64)
SALUTESPEECH_AUTHORIZATION_KEY=change_me_salutespeech_key

# ----- Telegram Bot (bot-workerservice) ------------------------------
# Токен бота, полученный у @BotFather
TELEGRAM_BOT_TOKEN=
# Разрешённые Telegram User ID через запятую (пустое = доступ всем)
TELEGRAM_ALLOWED_USER_IDS=

# ----- VK Bot (bot-workerservice) ------------------------------------
# Токен доступа сообщества (Bots Long Poll API)
VK_BOT_TOKEN=
# ID группы (числовой)
VK_BOT_GROUP_ID=0
# Разрешённые VK User ID через запятую (пустое = доступ всем)
VK_ALLOWED_USER_IDS=
