# =====================================================================
# Шаблон секретов backend для локальной разработки (запуск без Docker).
# Скопируйте в backend/.env и подставьте реальные значения:
#     cp backend/.env.example backend/.env
# Файл backend/.env НЕ коммитится в git (см. .gitignore).
# Значения автоматически загружаются в Program.cs (LoadDotEnv).
# Формат ключей: Section__Key (двойное подчёркивание = вложенность).
# =====================================================================

# Строка подключения к PostgreSQL (содержит пароль)
ConnectionStrings__DefaultConnection=Host=localhost;Database=ophthalmoguide;Username=postgres;Password=change_me

# Authentik (OIDC)
Authentik__ClientId=change_me_client_id
Authentik__ClientSecret=change_me_client_secret

# SaluteSpeech (Sber) — authorization key (base64) из личного кабинета SberDevices
SaluteSpeech__AuthorizationKey=change_me_salutespeech_key

# Разрешённые источники CORS для Production (если пусто, разрешает все анонимные для разработки)
# Cors__AllowedOrigins__0=https://your-production-domain.ru
