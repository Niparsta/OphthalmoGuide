        #     proxy_set_header X-Forwarded-Proto $scheme;
        #     proxy_set_header X-Forwarded-Host $host;
        # }

        location ^~ /health {
            limit_req zone=og_health burst=20 nodelay;
            limit_req_status 429;
            proxy_pass http://ophthalmoguide_backend;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
        }

        location ^~ /grafana {
            status_zone angie_grafana_proxy;
            resolver 127.0.0.11 valid=30s;
            set $grafana_upstream http://grafana:3000;
            proxy_pass $grafana_upstream;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
            
            # Rewrite both hosts in the OIDC redirect URL (the target and redirect_uri parameter) to the current requesting host
            proxy_redirect ~^(https?://)[^:/]+(:9443/application/o/authorize/\?client_id=[^&]+&redirect_uri=https%3A%2F%2F)[^%]+(%2Fgrafana%2Flogin%2Fgeneric_oauth.*)$ $1$host$2$host$3;
            
            # Standard redirects (like grafana internal login page or self-redirects)
            proxy_redirect ~^(https?://)[^:/]+:3000/(.*)$ https://$host/$2;
            proxy_redirect ~^(https?://)[^:/]+/(.*)$ https://$host/$2;
        }

        # Custom OphthalmoGuide themed error pages
        error_page 401 /401.html;
        location = /401.html {
            internal;
        }

        error_page 404 /404.html;
        location = /404.html {
            internal;
        }

        error_page 403 /403.html;
        location = /403.html {
            internal;
        }

        error_page 429 /429.html;
        location = /429.html {
            internal;
        }

        error_page 500 502 503 504 /50x.html;
        location = /50x.html {
            internal;
        }

        location ^~ /admin {
            limit_req zone=og_static burst=120 nodelay;
            limit_req_status 429;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
            add_header Pragma "no-cache" always;
            add_header Expires "0" always;
            try_files $uri $uri/ /index.html;
        }

        location / {
            limit_req zone=og_static burst=120 nodelay;
            limit_req_status 429;
            try_files $uri $uri/ /index.html;
        }
    }
}
